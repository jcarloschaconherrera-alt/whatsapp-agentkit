# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# Claude Code te ayuda a llenar estos valores durante el setup.
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
# Obtener en: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# ── Proveedor de WhatsApp ──────────────────────────────────
# Opciones: whapi | meta | twilio
WHATSAPP_PROVIDER=twilio

# ── Whapi.cloud (si WHATSAPP_PROVIDER=whapi) ──────────────
# Obtener en: https://whapi.cloud (plan gratis disponible)
WHAPI_TOKEN=

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────
# Configurar en: https://developers.facebook.com
# META_ACCESS_TOKEN=
# META_PHONE_NUMBER_ID=
# META_VERIFY_TOKEN=agentkit-verify

# ── Twilio (si WHATSAPP_PROVIDER=twilio) ──────────────────
# Configurar en: https://twilio.com
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Base de datos ─────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL en Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# ── Recolección de Datos — Reto 200→400 ──────────────────
# Número del equipo que recibe notificaciones cuando un lead completa el reto
# Formato internacional sin +: ej 521234567890 (México)
EQUIPO_WHATSAPP_NUMERO=

# Fuente por defecto si el lead llega por WhatsApp directo (sin tracking de Meta)
# Opciones: whatsapp | meta_ad | organico | tiktok | instagram
FUENTE_DEFAULT=whatsapp

# ── CRM API Key ───────────────────────────────────────────
# Key para proteger los endpoints /api/leads y /api/conversations
# Genera con: openssl rand -hex 32
CRM_API_KEY=
